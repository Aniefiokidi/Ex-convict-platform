# Copy to .env and update values
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/exconvict?schema=public"
# Next.js secret for iron-session
SESSION_PASSWORD="complex_password_at_least_32_chars_long"
NEXT_PUBLIC_SITE_URL="https://your-vercel-domain.vercel.app"
PORT=3000

# Optional, needed if file uploads are enabled
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
